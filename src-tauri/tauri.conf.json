{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Manuscript Archive",
  "version": "0.1.0",
  "identifier": "com.local.personalmanuscriptarchive",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Personal Manuscript Archive",
        "width": 1560,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
